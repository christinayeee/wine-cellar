document.addEventListener('dragover',e=>{const z=zoneOf(e.target);if(!z||!dragId)return;e.preventDefault();if(!z.classList.contains('drop-hi')){document.querySelectorAll('.drop-hi').forEach(x=>x.classList.remove('drop-hi'));z.classList.add('drop-hi');}});
function laneInsertIndex(lane,x){const cells=[...lane.querySelectorAll('.cell')];for(let i=0;i<cells.length;i++){const r=cells[i].getBoundingClientRect();if(x<r.left+r.width/2)return i;}return cells.length;}
document.addEventListener('drop',e=>{const z=zoneOf(e.target);if(!z||!dragId)return;e.preventDefault();const id=dragId;
  if(z.getAttribute('data-drop')==='bin')finish(id);else if(z.getAttribute('data-drop')==='tray')unplace(id);
  else if(z.dataset.lane){const[l,s]=z.dataset.lane.split('-');placeInLane(id,l,s,laneInsertIndex(z,e.clientX));}});

