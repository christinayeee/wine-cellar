const base=WINES.slice();
base.forEach((w,i)=>{w._id=w.loc?('L'+w.loc):('b'+i+'|'+w.winery+'|'+w.vintage);});
const LS='cwc:cellar_yyc';
let state={moves:{},meta:{},added:[],finished:[]};
try{Object.assign(state,JSON.parse(localStorage.getItem(LS)||'{}'))}catch(e){}
state.moves=state.moves||{};state.meta=state.meta||{};state.added=state.added||[];state.finished=state.finished||[];state.opened=state.opened||[];
try{const savedStruct=JSON.parse(localStorage.getItem(LS+':struct')||'null');if(savedStruct)STRUCTURE=savedStruct;}catch(e){}
function save(){try{localStorage.setItem(LS,JSON.stringify(state));localStorage.setItem(LS+':struct',JSON.stringify(STRUCTURE));}catch(e){}}
function allWines(){return base.concat(state.added)}
function wineById(id){return allWines().find(w=>w._id===id)}
function isFinished(w){return state.finished.includes(w._id)}
function isOpened(w){return state.opened.includes(w._id)}
function effLoc(w){if(isFinished(w))return null;if(w._id in state.moves)return state.moves[w._id];return w.loc;}
function subKey(loc){if(!loc)return null;const a=loc.split('-');return a[0]+'-'+a[1];}
function pOf(loc){return parseFloat(loc.split('-')[2]);}
function sublevelWines(l,s){return allWines().filter(w=>!isFinished(w)&&subKey(effLoc(w))===`${l}-${s}`).sort((a,b)=>pOf(effLoc(a))-pOf(effLoc(b)));}
function rankOf(w){const l=effLoc(w);if(!l)return null;const a=l.split('-');return sublevelWines(a[0],a[1]).indexOf(w)+1;}
function getR(w){return (state.meta[w._id]&&state.meta[w._id].r)||0}
function getN(w){return (state.meta[w._id]&&state.meta[w._id].n)||''}
function setMeta(w,k,v){state.meta[w._id]=state.meta[w._id]||{};state.meta[w._id][k]=v;save()}
function unfinish(id){state.finished=state.finished.filter(x=>x!==id)}
function placeInLane(id,l,s,index){const w=wineById(id);if(!w)return;unfinish(id);
  const list=sublevelWines(l,s).filter(x=>x._id!==id);let P;
  if(list.length===0)P=1;else if(index<=0)P=pOf(effLoc(list[0]))/2;else if(index>=list.length)P=pOf(effLoc(list[list.length-1]))+1;else P=(pOf(effLoc(list[index-1]))+pOf(effLoc(list[index])))/2;
  state.moves[id]=`${l}-${s}-${P}`;save();render();}
function unplace(id){unfinish(id);state.moves[id]=null;save();render();}
function openBottle(id){if(!state.opened.includes(id))state.opened.push(id);save();render();closeCard();}
function closeBottle(id){state.opened=state.opened.filter(x=>x!==id);save();render();closeCard();}
function finish(id){if(!state.finished.includes(id))state.finished.push(id);save();render();closeCard();}
function restore(id){unfinish(id);save();render();closeCard();}
function changeCap(l,s,delta){const arr=STRUCTURE[l];if(!arr)return;const i=s-1;if(i<0||i>=arr.length)return;const n=arr[i]+delta;if(n<1||n>20)return;arr[i]=n;save();render();}

