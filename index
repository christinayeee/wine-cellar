<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Christina's Wine Cellar</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500&display=swap');
:root{--cream:#faf5ed;--cream-2:#f6efe1;--card:#fffdf8;--ink:#5a4a3e;--ink-soft:#9a8b7b;--faint:#c3b6a2;--line:#e6dcc8;--line-2:#efe7d7;--wine:#a44a5c;--wine-soft:#c98b93;--cork:#d8b878;--cork-2:#c49a55;--blush:#d98a86;--leaf:#9caa88;--lane-odd:#fff9f2;--lane-even:#fdf3e8}
*{box-sizing:border-box}
html,body{margin:0;background:var(--cream);color:var(--ink);font-family:'Cormorant Garamond',Georgia,'Songti SC',serif;-webkit-font-smoothing:antialiased;font-size:16px}
.ui,button,input,select,textarea{font-family:'Inter',system-ui,'PingFang SC','Microsoft YaHei',sans-serif}
.wrap{max-width:1180px;margin:0 auto;padding:36px 28px 90px}
.hd{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:20px}
.brand{display:flex;align-items:flex-end;gap:16px}
.brand h1{font-family:'Dancing Script',cursive;font-weight:700;font-size:58px;line-height:1;margin:0;color:var(--wine)}
.brand .sub{font-size:13px;letter-spacing:.32em;text-transform:uppercase;color:var(--ink-soft);margin:11px 0 0 4px;font-weight:500}
.statline{display:flex;gap:26px}.statline .s{text-align:center}
.statline .s b{display:block;font-family:'Dancing Script',cursive;font-weight:700;font-size:32px;line-height:1;color:var(--ink)}
.statline .s span{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}
.hero{text-align:center;margin:22px 0 20px}
.hero .gart{display:block}.gart svg{width:240px;height:auto;display:block;margin:0 auto 4px}
.hero .subtitle{font-size:13px;letter-spacing:.32em;text-transform:uppercase;color:var(--ink-soft);font-weight:500}
.bar{display:flex;flex-wrap:wrap;align-items:center;gap:8px;margin-bottom:10px}
.bar .lbl{font-style:italic;font-size:15px;color:var(--ink-soft)}
.pills{display:inline-flex;background:var(--card);border:1px solid var(--line);border-radius:22px;padding:3px;gap:2px;flex-wrap:wrap}
.pills button{border:0;background:transparent;color:var(--ink-soft);font-size:12.5px;padding:6px 12px;border-radius:18px;cursor:pointer;transition:.15s;white-space:nowrap}
.pills button:hover{color:var(--ink)}.pills button.on{background:var(--wine);color:#fff}
.addbtn{border:1px solid var(--wine);background:var(--wine);color:#fff;border-radius:22px;padding:8px 15px;font-size:13px;cursor:pointer}.addbtn:hover{background:#873a48}
.search{margin-left:auto;display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--line);border-radius:22px;padding:7px 14px;min-width:170px}
.search input{border:0;background:transparent;outline:none;font-size:13px;color:var(--ink);width:100%}.search input::placeholder{color:var(--faint)}
.legend{display:flex;flex-wrap:wrap;gap:14px;margin:6px 0 12px;font-size:13px;color:var(--ink-soft)}
.legend span{display:inline-flex;align-items:center;gap:7px}.sw{width:11px;height:11px;border-radius:50%}
.hint{font-size:12.5px;font-style:italic;color:var(--faint);margin:0 0 22px}
.cabinet{border:1.5px solid var(--line);border-radius:24px;padding:8px 16px 20px;background:linear-gradient(180deg,#fff 0%,transparent 200px)}
.shelf{padding:10px 0 6px}.shelf+.shelf{border-top:1px dashed var(--line-2)}
.shelf-hd{display:flex;align-items:baseline;gap:10px;margin:2px 0 6px 4px;flex-wrap:wrap}
.shelf-hd .no{font-family:'Dancing Script',cursive;font-weight:700;font-size:38px;color:var(--wine);line-height:1;transform:rotate(-3deg);display:inline-block}
.shelf-hd .ttl{font-style:italic;font-size:14px;color:var(--ink-soft);margin-left:2px}
.shelf-hd .fill{margin-left:auto;font-size:12px;color:var(--faint);padding-right:6px}.shelf-hd .fill.over{color:var(--wine)}
.cap-ctrl{display:flex;align-items:center;gap:5px;margin-left:10px}
.cap-ctrl button{width:22px;height:22px;border:1px solid var(--line);background:var(--card);border-radius:6px;color:var(--ink-soft);font-size:14px;line-height:1;cursor:pointer;padding:0}.cap-ctrl button:hover{border-color:var(--wine-soft);color:var(--wine)}
.cap-ctrl span{font-size:11px;color:var(--faint);min-width:20px;text-align:center}
.lane{margin:6px 0;border-radius:14px;transition:background .12s,box-shadow .12s;padding:8px 6px 4px}
.lane:nth-child(odd){background:var(--lane-odd)}
.lane:nth-child(even){background:var(--lane-even)}
.lane.drop-hi{background:rgba(164,74,92,.08)!important;box-shadow:inset 0 0 0 1.5px var(--wine-soft)}
.lane .slots{display:flex;flex-wrap:nowrap;gap:8px;align-items:flex-end;padding:2px 6px}
.shelfline{height:0;border-bottom:1.5px solid var(--line);margin:2px 12px 0;position:relative}
.shelfline::before,.shelfline::after{content:"";position:absolute;bottom:-3px;width:1.5px;height:6px;background:var(--line)}
.shelfline::before{left:0}.shelfline::after{right:0}
.subtag{font-size:10px;letter-spacing:.08em;color:var(--faint);margin:4px 0 0 14px;text-transform:uppercase}
.cell{flex:1 1 0;min-width:46px;max-width:160px;background:none;border:0;padding:2px 2px 0;cursor:grab;display:flex;flex-direction:column;align-items:center;transition:transform .18s ease}
.cell.vert{max-width:78px}.cell:active{cursor:grabbing}
.cell svg{width:100%;height:auto;display:block;overflow:visible;pointer-events:none}
.cell.dragging{opacity:.35}.cell:hover{transform:translateY(-5px)}.cell.sel .glass{stroke:var(--wine);stroke-width:2.2}.cell.dim{opacity:.22}
.cap{margin-top:6px;text-align:center;line-height:1.15;max-width:100%;pointer-events:none}
.cap .nm{font-size:12px;font-weight:500;color:var(--ink);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.cap .yr{font-family:'Inter';font-size:10px;color:var(--faint);margin-top:2px}
.cap .rt{color:var(--wine);font-size:10px;letter-spacing:1px}
.ph{flex:1 1 0;min-width:46px;max-width:160px}.ph.vert{max-width:78px}.ph svg{width:100%;height:auto;display:block}
.zones{display:grid;grid-template-columns:1fr 300px;gap:22px;margin-top:30px;align-items:start}
@media(max-width:820px){.zones{grid-template-columns:1fr}}
.zone{border:1.5px dashed var(--line);border-radius:18px;padding:16px 18px;min-height:120px;transition:.12s}
.zone.drop-hi{border-color:var(--wine-soft);background:rgba(164,74,92,.05)}
.zone h3{font-family:'Dancing Script',cursive;font-weight:700;font-size:26px;margin:0 0 2px;color:var(--wine);display:flex;align-items:center;gap:8px}.zone h3 svg{width:34px;height:26px}
.zone p{font-size:13px;font-style:italic;color:var(--ink-soft);margin:0 0 12px}
.tray-row{display:flex;gap:12px;flex-wrap:wrap}.tray-row .cell{flex:0 0 110px}
.bin{background:linear-gradient(180deg,#f0e6d0,#e8dabb);border:1.5px solid var(--cork-2);border-radius:14px 14px 20px 20px}
.bin-corks{display:flex;flex-wrap:wrap;gap:9px;min-height:42px;align-items:center}
.cork{cursor:pointer;transition:transform .14s}.cork:hover{transform:translateY(-3px) rotate(-4deg)}.cork svg{width:24px;height:32px;display:block}
.bin .empty-note{font-size:12.5px;font-style:italic;color:var(--faint)}
.vignette{display:flex;justify-content:center;margin:44px 0 6px;opacity:.9}.vignette svg{width:260px;height:160px}
.foot{margin-top:8px;text-align:center;font-style:italic;font-size:14px;color:var(--ink-soft)}
.scrim{position:fixed;inset:0;background:rgba(70,55,45,.34);backdrop-filter:blur(3px);display:none;align-items:center;justify-content:center;z-index:50;padding:22px}
.scrim.show{display:flex}
.card{width:min(480px,95vw);max-height:92vh;overflow-y:auto;background:var(--card);border:1px solid var(--line);border-radius:22px;padding:30px 30px 26px;position:relative;box-shadow:0 30px 70px rgba(90,74,62,.2);animation:rise .22s cubic-bezier(.2,.8,.2,1)}
@keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
.card .x{position:absolute;right:16px;top:12px;border:0;background:transparent;color:var(--faint);font-size:24px;cursor:pointer}.card .x:hover{color:var(--ink)}
.card .fam{display:inline-flex;align-items:center;gap:7px;font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:8px}
.card h2{font-family:'Dancing Script',cursive;font-weight:700;font-size:31px;line-height:1.04;margin:0;color:var(--wine)}
.card .vint{font-size:15px;color:var(--ink-soft);margin:9px 0 16px}.card .vint b{font-family:'Dancing Script',cursive;font-size:23px;color:var(--ink);font-weight:700}
.meta{display:grid;grid-template-columns:1fr 1fr;gap:13px 18px;border-top:1px solid var(--line);padding-top:15px}
.meta label{display:block;font-size:10px;letter-spacing:.11em;text-transform:uppercase;color:var(--faint);margin-bottom:3px}.meta div{font-size:15px}
.sect{margin-top:16px;border-top:1px solid var(--line);padding-top:14px}
.sect .lab{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--faint);margin-bottom:6px;display:flex;align-items:center;gap:7px}
.sect p{margin:0;font-size:14.5px;line-height:1.55;color:var(--ink)}
.sect .blend{font-family:'Inter';font-size:12px;color:var(--ink-soft);margin:2px 0 6px;font-style:italic}
.vivino{margin-top:16px;border-top:1px solid var(--line);padding-top:15px;display:flex;align-items:center;justify-content:space-between;gap:12px}
.vivino .vscore{display:flex;align-items:baseline;gap:9px}
.vivino .vnum{font-family:'Dancing Script',cursive;font-weight:700;font-size:32px;color:var(--wine);line-height:1}
.vivino .vlab{font-size:11px;letter-spacing:.05em;text-transform:uppercase;color:var(--faint)}
.vivino .vlab b{display:block;font-family:'Inter';font-size:12px;color:var(--ink-soft);text-transform:none;letter-spacing:0;font-weight:400;font-style:italic}
.mine{margin-top:16px;border-top:1px solid var(--line);padding-top:14px}
.mine .lab{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--faint);margin-bottom:8px}
.mine .lab em{font-style:normal;text-transform:none;letter-spacing:0;color:var(--faint);font-size:11px}
.stars{display:flex;align-items:center;gap:6px;margin-bottom:16px}
.stars .st{font-size:26px;line-height:1;color:var(--line);cursor:pointer;transition:.12s;user-select:none}.stars .st.on{color:var(--wine)}.stars .st:hover{transform:scale(1.15)}
.clear{font-size:11px;color:var(--faint);background:transparent;border:0;cursor:pointer;margin-left:8px}.clear:hover{color:var(--wine)}
textarea{width:100%;min-height:70px;resize:vertical;border:1px solid var(--line);border-radius:14px;padding:11px 13px;font-size:14px;color:var(--ink);background:var(--cream);outline:none;line-height:1.5}
textarea:focus{border-color:var(--wine-soft);background:#fff}
.saved{font-size:11px;color:var(--faint);margin-top:6px;height:14px}
.lnk{display:inline-flex;align-items:center;gap:5px;font-size:12px;padding:7px 13px;border-radius:16px;border:1px solid var(--line);color:var(--wine);text-decoration:none;background:var(--cream);white-space:nowrap;transition:.14s}.lnk:hover{background:var(--wine);color:#fff;border-color:var(--wine)}
.cardbtns{margin-top:18px;display:flex;gap:10px;flex-wrap:wrap}
.btn2{font-size:12.5px;padding:8px 14px;border-radius:16px;border:1px solid var(--line);background:var(--cream);color:var(--ink);cursor:pointer}.btn2:hover{border-color:var(--wine-soft)}.btn2.wine{border-color:var(--wine);color:var(--wine)}
.form h2{font-family:'Dancing Script',cursive;font-weight:700;font-size:32px;color:var(--wine);margin:0 0 4px}
.form p{font-size:13px;font-style:italic;color:var(--ink-soft);margin:0 0 16px}
.field{margin-bottom:12px}.field label{display:block;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:4px}
.field input,.field select{width:100%;border:1px solid var(--line);border-radius:11px;padding:9px 12px;font-size:14px;color:var(--ink);background:var(--cream);outline:none}
.field input:focus,.field select:focus{border-color:var(--wine-soft);background:#fff}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form .go{width:100%;margin-top:8px;border:0;background:var(--wine);color:#fff;border-radius:14px;padding:12px;font-size:14px;cursor:pointer}.form .go:hover{background:#873a48}
#gate{position:fixed;inset:0;z-index:200;background:radial-gradient(120% 90% at 50% 0%,#fff7ea,var(--cream));display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:26px;text-align:center}
#gate.hide{display:none}
#gate h1{font-family:'Dancing Script',cursive;font-weight:700;font-size:46px;color:var(--wine);margin:0}
#gate .gsub{font-size:13px;letter-spacing:.28em;text-transform:uppercase;color:var(--ink-soft);margin:6px 0 22px}
#gate .grow{display:flex;gap:10px;align-items:center}
#gate input{border:1.5px solid var(--line);border-radius:14px;padding:12px 16px;font-size:16px;color:var(--ink);background:var(--card);outline:none;width:200px;text-align:center;letter-spacing:.2em}
#gate input:focus{border-color:var(--wine-soft)}
#gate button{border:0;background:var(--wine);color:#fff;border-radius:14px;padding:12px 20px;font-size:15px;cursor:pointer}
#gate button:hover{background:#873a48}
#gate .gerr{color:var(--wine);font-size:13px;height:18px;margin-top:12px;font-style:italic}
.flag{display:inline-flex;vertical-align:middle}.flag svg{width:15px;height:10px;border:.5px solid rgba(90,74,62,.2);border-radius:2px}
.info2{margin-top:16px;border-top:1px solid var(--line);padding-top:14px}
.info2 .irow{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:4px 0}
.info2 .ilab{font-size:12.5px;color:var(--ink-soft)}
.info2 .ival{font-size:14px;color:var(--ink);display:flex;align-items:center;gap:8px}
.info2 .ival b{font-family:'Dancing Script',cursive;font-size:22px;color:var(--wine);font-weight:700}
.info2 .ival em{font-style:italic;color:var(--faint);font-size:11px}
.lnk.sm{padding:4px 9px;font-size:11px}
.info2 .inote{font-size:10.5px;color:var(--faint);font-style:italic;margin-top:7px;line-height:1.45}
.score-row{display:flex;gap:16px;margin-top:10px;flex-wrap:wrap}
.score-pill{background:var(--cream);border:1px solid var(--line);border-radius:14px;padding:8px 14px;text-align:center;min-width:90px}
.score-pill .slab{font-size:10px;color:var(--faint);letter-spacing:.05em}
.score-pill .sval{font-family:'Dancing Script',cursive;font-size:24px;color:var(--wine);font-weight:700;line-height:1}
.sync-hint{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:var(--ink-soft);margin:0 0 14px;padding:10px 14px;background:var(--card);border:1px solid var(--line);border-radius:14px;font-family:'Cormorant Garamond',Georgia,'Songti SC',serif;line-height:1.5}
.sync-hint b{font-family:'Cormorant Garamond',Georgia,'Songti SC',serif;font-weight:700;color:var(--ink)}
.io-group{display:flex;gap:6px;align-items:center}
.io-btn{font-size:12.5px;padding:7px 13px;border-radius:16px;border:1px solid var(--line);background:var(--card);color:var(--ink);cursor:pointer;font-family:'Cormorant Garamond',Georgia,'Songti SC',serif;transition:.14s}
.io-btn:hover{border-color:var(--wine-soft);color:var(--wine)}
</style>
</head>
<body>
<div id="gate">
  <!-- Cute capybara with wine glass -->
  <div style="margin-bottom:14px">
    <svg viewBox="0 0 140 110" width="140" height="110" xmlns="http://www.w3.org/2000/svg">
      <g fill="none" stroke="#5a4a3e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <!-- Body -->
        <ellipse cx="70" cy="72" rx="38" ry="28" fill="#c4a882" fill-opacity="0.25"/>
        <!-- Head -->
        <ellipse cx="70" cy="38" rx="22" ry="20" fill="#c4a882" fill-opacity="0.3"/>
        <!-- Ears -->
        <ellipse cx="52" cy="26" rx="6" ry="5" fill="#c4a882" fill-opacity="0.35"/>
        <ellipse cx="88" cy="26" rx="6" ry="5" fill="#c4a882" fill-opacity="0.35"/>
        <!-- Small round ears inner -->
        <ellipse cx="52" cy="27" rx="3" ry="2.5" fill="#d4b896" fill-opacity="0.5" stroke="none"/>
        <ellipse cx="88" cy="27" rx="3" ry="2.5" fill="#d4b896" fill-opacity="0.5" stroke="none"/>
        <!-- Eyes -->
        <circle cx="60" cy="36" r="2.2" fill="#5a4a3e" stroke="none"/>
        <circle cx="80" cy="36" r="2.2" fill="#5a4a3e" stroke="none"/>
        <!-- Nose -->
        <ellipse cx="70" cy="45" rx="4" ry="3" fill="#a44a5c" fill-opacity="0.6" stroke="none"/>
        <!-- Mouth -->
        <path d="M66,50 Q70,53 74,50" stroke-width="1"/>
        <!-- Blush -->
        <ellipse cx="54" cy="42" rx="4" ry="2.5" fill="#d98a86" fill-opacity="0.35" stroke="none"/>
        <ellipse cx="86" cy="42" rx="4" ry="2.5" fill="#d98a86" fill-opacity="0.35" stroke="none"/>
        <!-- Paws -->
        <ellipse cx="46" cy="92" rx="7" ry="5" fill="#c4a882" fill-opacity="0.3"/>
        <ellipse cx="94" cy="92" rx="7" ry="5" fill="#c4a882" fill-opacity="0.3"/>
        <!-- Wine glass in right paw -->
        <g transform="translate(88,58)">
          <path d="M4,0 Q4,10 10,14 Q16,10 16,0" fill="#a44a5c" fill-opacity="0.35" stroke-width="1"/>
          <line x1="10" y1="14" x2="10" y2="26" stroke-width="1"/>
          <line x1="6" y1="26" x2="14" y2="26" stroke-width="1"/>
        </g>
        <!-- Tiny vine leaves -->
        <path d="M32,60 Q28,56 32,52 Q36,56 32,60" fill="#9caa88" fill-opacity="0.4" stroke="none"/>
        <path d="M108,56 Q104,52 108,48 Q112,52 108,56" fill="#9caa88" fill-opacity="0.4" stroke="none"/>
      </g>
    </svg>
  </div>
  <h1>Christina's Wine Cellar</h1>
  <div class="gsub">请输入密码</div>
  <div class="grow"><input id="gpw" type="password" inputmode="numeric" placeholder="密码" autocomplete="off"><button id="gbtn">进入 →</button></div>
  <div class="gerr" id="gerr"></div>
</div>
<div class="wrap">
  <div class="hd">
    <div class="brand">
      <div>
        <h1>Christina's Wine Cellar</h1>
        <div class="sub">Christina's Wine Cellar</div>
      </div>
    </div>
    <div class="statline" id="statline"></div>
  </div>
  <div class="hero" id="heroArt">
    <div class="gart">
      <svg viewBox="0 0 320 140" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g stroke="var(--ink)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <!-- Girl figure -->
          <circle cx="90" cy="42" r="11" fill="none"/>
          <path d="M79 56 Q76 62 76 70 L76 92" fill="none"/>
          <path d="M101 56 Q104 62 104 70 L104 92" fill="none"/>
          <!-- pink dress -->
          <path d="M79 56 L101 56 L108 80 Q110 86 104 86 L76 86 Q70 86 72 80 Z" fill="var(--blush)" fill-opacity=".2"/>
          <!-- long hair -->
          <path d="M79 42 Q72 48 72 58 Q72 68 76 74" fill="none" stroke-width="1.2"/>
          <path d="M101 42 Q108 48 108 58 Q108 68 104 74" fill="none" stroke-width="1.2"/>
          <!-- blush -->
          <circle cx="84" cy="44" r="2" fill="var(--blush)" fill-opacity=".35" stroke="none"/>
          <circle cx="96" cy="44" r="2" fill="var(--blush)" fill-opacity=".35" stroke="none"/>
          <!-- wine glass (right hand) -->
          <path d="M108 58 L114 70 M102 70 L120 70" fill="none"/>
          <ellipse cx="111" cy="70" rx="6" ry="2" fill="var(--wine)" fill-opacity=".2"/>
          <path d="M111 72 L111 78" fill="none"/>
          <!-- Boy figure -->
          <circle cx="230" cy="42" r="11" fill="none"/>
          <path d="M219 56 Q216 62 216 70 L216 92" fill="none"/>
          <path d="M241 56 Q244 62 244 70 L244 92" fill="none"/>
          <!-- blue shirt -->
          <path d="M219 56 L241 56 L246 78 Q248 84 242 84 L218 84 Q212 84 214 78 Z" fill="#8a9eb5" fill-opacity=".2"/>
          <!-- short hair -->
          <path d="M219 36 Q230 28 241 36" fill="none" stroke-width="1.2"/>
          <!-- blush -->
          <circle cx="224" cy="44" r="2" fill="var(--blush)" fill-opacity=".35" stroke="none"/>
          <circle cx="236" cy="44" r="2" fill="var(--blush)" fill-opacity=".35" stroke="none"/>
          <!-- wine glass (left hand) -->
          <path d="M206 58 L200 70 M194 70 L212 70" fill="none"/>
          <ellipse cx="203" cy="70" rx="6" ry="2" fill="var(--wine)" fill-opacity=".2"/>
          <path d="M203 72 L203 78" fill="none"/>
          <!-- Clinking effect -->
