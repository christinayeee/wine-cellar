function shortName(w){let s=w.winery;const map=[['Barons de Rothschild Lafite Collection Reserve Speciale','Lafite Rés. Spéciale'],['Pichon-Longueville Comtesse de Lalande','Pichon Comtesse'],['Bennati Cerasum Riserva della Famiglia Bennati Amarone della Valpolicella Riserva DOCG','Bennati Amarone'],['东风酒庄陶罐自然甜红葡萄酒','东风·自然甜红'],['Sine Qua Non','SQN'],['Chateau Petrus','Pétrus'],['Chateau ',''],['Château ',''],[' Premier Grand Cru',''],[' Estate Grown',''],[' Gran Reserva','']];
  for(const [a,b] of map) s=s.split(a).join(b);
