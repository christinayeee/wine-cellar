    <div class="sect"><div class="lab">📖 关于这瓶</div><p>${wineDesc(w)}</p></div>
    <div class="info2">
      <div class="irow"><div class="ilab">Vivino 评分</div><div class="ival">${vv?`<b>${w.vest?'≈':''}${vv}</b> / 5${w.vest?' <em>参考</em>':''}`:'<em>暂无</em>'}<a class="lnk sm" target="_blank" rel="noopener" href="${vvUrl(w)}">↗</a></div></div>
      <div class="irow"><div class="ilab">参考市场价</div><div class="ival">${w.price?`<b>≈ $${Number(w.price).toLocaleString()}</b> <em>/瓶</em>`:'<em>暂无</em>'}<a class="lnk sm" target="_blank" rel="noopener" href="${wsUrl(w)}">查实时价 ↗</a></div></div>
      <div class="inote">Vivino 评分与市场价均为参考，随年份、批次与市场波动；以链接的实时数据为准。</div>
    </div>
    ${(rpBadge||wsBadge)?`<div class="score-row">${rpBadge}${wsBadge}</div>`:''}
    <div class="mine"><div class="lab">我的评分 <em>· 喝过再打，没喝可留空</em></div><div class="stars" id="stars">${starRow(w)}</div><div class="lab">我的品尝笔记</div><textarea id="note" placeholder="香气、口感、和谁一起喝的、配了什么、还想不想再买……">${esc(getN(w))}</textarea><div class="saved" id="saved"></div></div>
    <div class="cardbtns">${isFinished(w)?`<button class="btn2 wine" data-restore="${esc(w._id)}">↩ 放回酒柜</button>`:`<button class="btn2" data-finish="${esc(w._id)}">🥂 标为喝完</button>`}
      ${!isFinished(w)?(isOpened(w)?`<button class="btn2 open" data-close-bottle="${esc(w._id)}">🔒 关闭酒瓶</button>`:`<button class="btn2 open" data-open-bottle="${esc(w._id)}">🍷 标记已开瓶</button>`):''}
    </div>`;
  const stars=card.querySelector('#stars');
  stars.querySelectorAll('.st').forEach(el=>{el.addEventListener('mouseenter',()=>{const v=+el.dataset.v;stars.querySelectorAll('.st').forEach(x=>x.classList.toggle('on',+x.dataset.v<=v));});el.addEventListener('click',()=>{setMeta(w,'r',+el.dataset.v);paintStars(w);render();});});
  stars.querySelector('.clear').addEventListener('click',()=>{setMeta(w,'r',0);paintStars(w);render();});
  stars.addEventListener('mouseleave',()=>paintStars(w));
  const ta=card.querySelector('#note'),sv=card.querySelector('#saved');let t;
  ta.addEventListener('input',()=>{clearTimeout(t);t=setTimeout(()=>{setMeta(w,'n',ta.value);sv.textContent='已保存 ✓';setTimeout(()=>sv.textContent='',1200);},400);});
  scrim.classList.add('show');}
window.closeCard=()=>scrim.classList.remove('show');
scrim.addEventListener('click',e=>{if(e.target===scrim||e.target.hasAttribute('data-close'))closeCard();});
document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeCard();closeForm();}});
document.body.addEventListener('click',e=>{const fin=e.target.closest('[data-finish]');if(fin){finish(fin.dataset.finish);return;}const res=e.target.closest('[data-restore]');if(res){restore(res.dataset.restore);return;}const cork=e.target.closest('[data-cork]');if(cork){const w=wineById(cork.dataset.cork);if(w)openCard(w);return;}const ob=e.target.closest('[data-open-bottle]');if(ob){openBottle(ob.dataset.openBottle);return;}
  const cb=e.target.closest('[data-close-bottle]');if(cb){closeBottle(cb.dataset.closeBottle);return;}
  const c=e.target.closest('.cell');if(c){const w=wineById(c.dataset.id);if(w){document.querySelectorAll('.cell.sel').forEach(x=>x.classList.remove('sel'));c.classList.add('sel');openCard(w);}}});

const formScrim=document.getElementById('formScrim'),formCard=document.getElementById('formCard');
function openForm(){const opts=grapeOrder().map(g=>`<option value="${g}">${GRAPE[g].label}</option>`).join('');
  formCard.innerHTML=`<button class="x" data-cform>×</button><h2>新增一瓶</h2><p>填好后它会出现在「还没归位」，再拖进柜子就行。</p>
    <div class="field"><label>酒名 *</label><input id="f_winery" placeholder="如 Screaming Eagle / Chateau Palmer"></div>
    <div class="frow"><div class="field"><label>年份</label><input id="f_vintage" placeholder="2019" inputmode="numeric"></div><div class="field"><label>主要葡萄品种</label><select id="f_grape">${opts}</select></div></div>
    <div class="frow"><div class="field"><label>国家</label><input id="f_country" placeholder="France / USA…"></div><div class="field"><label>产区</label><input id="f_region" placeholder="如 Napa Valley"></div></div>
    <div class="field"><label>混酿比例（可选）</label><input id="f_graw" placeholder="如 60% Cabernet, 40% Merlot"></div>
    <button class="go" id="f_go">加入酒柜</button>`;
  formCard.querySelector('#f_go').addEventListener('click',()=>{const winery=formCard.querySelector('#f_winery').value.trim();if(!winery){formCard.querySelector('#f_winery').focus();return;}const vRaw=formCard.querySelector('#f_vintage').value.trim();
    state.added.push({_id:'u'+Date.now(),winery,name:null,vintage:vRaw?(parseInt(vRaw,10)||vRaw):null,grape:formCard.querySelector('#f_grape').value,grapeRaw:formCard.querySelector('#f_graw').value.trim()||null,country:formCard.querySelector('#f_country').value.trim()||null,region:formCard.querySelector('#f_region').value.trim()||null,loc:null,vivino:null,vest:false,bottle:null,rp:null,ws:null,price:null});
    save();buildLegend();buildCountryFilter();wireCountry();render();closeForm();document.getElementById('trayZone').scrollIntoView({behavior:'smooth',block:'center'});});
  formScrim.classList.add('show');}
window.closeForm=()=>formScrim.classList.remove('show');
formScrim.addEventListener('click',e=>{if(e.target===formScrim||e.target.hasAttribute('data-cform'))closeForm();});
document.getElementById('addBtn').addEventListener('click',openForm);

let fc='all',fr='all',fo='all',fq='';
function applyFilters(){document.querySelectorAll('.cell').forEach(b=>{const w=wineById(b.dataset.id);if(!w)return;let ok=true;
  if(fo!=='all'){const op=isOpened(w);if(fo==='open'&&!op)ok=false;if(fo==='closed'&&op)ok=false;}
  if(fc!=='all'&&w.country!==fc)ok=false;
  if(fr!=='all'){const r=getR(w);if(fr==='0'&&r!==0)ok=false;if(fr==='4'&&r<4)ok=false;if(fr==='3'&&r<3)ok=false;}
  if(fq){const hay=`${w.winery} ${w.region||''} ${w.grape||''} ${w.grapeRaw||''} ${w.vintage||''}`.toLowerCase();if(!hay.includes(fq))ok=false;}
  b.classList.toggle('dim',!ok);});}
function wire(id,fn){document.getElementById(id).addEventListener('click',e=>{const btn=e.target.closest('button');if(!btn)return;[...e.currentTarget.children].forEach(x=>x.classList.toggle('on',x===btn));fn(btn);});}
function wireCountry(){const el=document.getElementById('fCountry');el.onclick=e=>{const btn=e.target.closest('button');if(!btn)return;[...el.children].forEach(x=>x.classList.toggle('on',x===btn));fc=btn.dataset.c;applyFilters();};}
wire('fRate',b=>{fr=b.dataset.r;applyFilters();});
const fOpenEl=document.getElementById('fOpen');fOpenEl.onclick=e=>{const btn=e.target.closest('button');if(!btn)return;[...fOpenEl.children].forEach(x=>x.classList.toggle('on',x===btn));fo=btn.dataset.o;applyFilters();};
document.getElementById('q').addEventListener('input',e=>{fq=e.target.value.trim().toLowerCase();applyFilters();});

buildLegend();buildCountryFilter();wireCountry();render();

/* export / import backup */
function exportData(){const blob=new Blob([JSON.stringify({version:2,timestamp:Date.now(),data:state,structure:STRUCTURE},null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='christina-wine-cellar-'+new Date().toISOString().slice(0,10)+'.json';a.click();}
function importData(file){const r=new FileReader();r.onload=e=>{try{const obj=JSON.parse(e.target.result);if(obj.data){Object.assign(state,obj.data);}if(obj.structure)STRUCTURE=obj.structure;save();buildLegend();buildCountryFilter();wireCountry();render();alert('恢复成功 ✓');}catch(err){alert('文件格式不对，请选正确的备份文件');}};r.readAsText(file);}
document.getElementById('exportBtn').addEventListener('click',exportData);
document.getElementById('importBtn').addEventListener('click',()=>document.getElementById('importFile').click());
document.getElementById('importFile').addEventListener('change',e=>{const f=e.target.files[0];if(f)importData(f);e.target.value='';});

/* cross-tab sync via storage event */
window.addEventListener('storage',ev=>{if(ev.key===LS||ev.key===LS+':struct'){try{const raw=JSON.parse(localStorage.getItem(LS)||'{}');Object.assign(state,raw);const s=JSON.parse(localStorage.getItem(LS+':struct')||'null');if(s)STRUCTURE=s;render();}catch(e){}}});

(function(){const gate=document.getElementById('gate'),pw=document.getElementById('gpw'),btn=document.getElementById('gbtn'),err=document.getElementById('gerr');const PW='123456';
  function ok(){gate.classList.add('hide');try{sessionStorage.setItem('yyc:auth','1')}catch(e){}}
  try{if(sessionStorage.getItem('yyc:auth')==='1')gate.classList.add('hide');}catch(e){}
  function tryit(){if(pw.value===PW)ok();else{err.textContent='密码不对，再试一次～';pw.value='';pw.focus();}}
  btn.addEventListener('click',tryit);pw.addEventListener('keydown',e=>{if(e.key==='Enter')tryit();});
  if(!gate.classList.contains('hide'))setTimeout(()=>pw.focus(),100);})();
</script>
</body>
</html>
