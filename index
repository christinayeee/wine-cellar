  const opened=act.filter(isOpened).length;document.getElementById('statline').innerHTML=[['在柜',act.length],['酒庄',wineries],['年份',(Math.min(...yrs))+'–'+(Math.max(...yrs))],['已开',opened]].map(([k,v])=>`<div class="s"><b>${v}</b><span>${k}</span></div>`).join('');}
