function render(){let html='';
  for(const lvl of Object.keys(STRUCTURE)){const subs=STRUCTURE[lvl];const cap=subs.reduce((a,b)=>a+b,0);const vert=STANDING.includes(+lvl);
    let filled=0;const order=subs.map((x,i)=>i+1).reverse();let lanes='';
    for(const s of order){const arr=sublevelWines(lvl,s);filled+=arr.length;const nominal=subs[s-1];
      let slots=arr.map(w=>cellHTML(w,vert)).join('');
      for(let k=arr.length;k<nominal;k++)slots+=`<div class="ph${vert?' vert':''}">${vert?emptyStanding():emptyLying()}</div>`;
      lanes+=`<div class="lane" data-lane="${lvl}-${s}"><div class="slots">${slots}</div><div class="shelfline"></div>${subs.length>1?`<div class="subtag">S${s} · 容量 ${nominal} <span class="cap-ctrl"><button onclick="changeCap(${lvl},${s},-1)">−</button><span>${nominal}</span><button onclick="changeCap(${lvl},${s},1)">+</button></span></div>`:`<div class="subtag">容量 ${nominal} <span class="cap-ctrl"><button onclick="changeCap(${lvl},${s},-1)">−</button><span>${nominal}</span><button onclick="changeCap(${lvl},${s},1)">+</button></span></div>`}</div>`;}
    const over=filled>cap;
    html+=`<div class="shelf"><div class="shelf-hd"><span class="no">${String(lvl).padStart(2,'0')}</span><span class="ttl">第 ${lvl} 层${vert?' · 站立摆放':''}</span><span class="fill${over?' over':''}">${filled} / ${cap}</span></div>${lanes}</div>`;}
  document.getElementById('shelves').innerHTML=html;
  const tray=allWines().filter(w=>!isFinished(w)&&!effLoc(w));
  document.getElementById('trayList').innerHTML=tray.length?tray.map(w=>cellHTML(w,false)).join(''):'<p style="color:var(--faint);font-style:italic;font-size:13px">都归位啦 ✿</p>';
  const fin=allWines().filter(isFinished);
  document.getElementById('binList').innerHTML=fin.length?fin.map(w=>`<div class="cork" data-cork="${esc(w._id)}" title="${esc(w.winery)} ${w.vintage||''}">${corkSVG()}</div>`).join(''):'<span class="empty-note">还没有喝完的～</span>';
  updateStats();applyFilters();}
function updateStats(){const act=allWines().filter(w=>!isFinished(w));
